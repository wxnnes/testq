<script>
// ── DATA ─────────────────────────────────────────────────────────
const WERKPLEKKEN = [
  { id: 'wp1',  name: 'Werkplek 1',   desc: 'Glazen bureau',              group: 'Glazen bureau' },
  { id: 'wp2',  name: 'Werkplek 2',   desc: 'Linkerblok, links venster',  group: 'Linkerblok' },
  { id: 'wp3',  name: 'Werkplek 3',   desc: 'Linkerblok, links keuken',   group: 'Linkerblok' },
  { id: 'wp4',  name: 'Werkplek 4',   desc: 'Linkerblok, rechts venster', group: 'Linkerblok' },
  { id: 'wp5',  name: 'Werkplek 5',   desc: 'Linkerblok, rechts keuken',  group: 'Linkerblok' },
  { id: 'wp6',  name: 'Werkplek 6',   desc: 'Rechterblok, links venster', group: 'Rechterblok' },
  { id: 'wp7',  name: 'Werkplek 7',   desc: 'Rechterblok, links keuken',  group: 'Rechterblok' },
  { id: 'wp8',  name: 'Werkplek 8',   desc: 'Rechterblok, rechts venster',group: 'Rechterblok' },
  { id: 'wp9',  name: 'Werkplek 9',   desc: 'Rechterblok, rechts keuken', group: 'Rechterblok' },
  { id: 'vz',   name: 'Vergaderzaal', desc: '',                            group: 'Ruimtes' },
  { id: 'kr',   name: 'Kleine ruimte',desc: '',                            group: 'Ruimtes' },
];
const HOURS = [8,9,10,11,12,13,14,15,16];
const PARKING_SPOTS = [
  { id: 'pk_links',    name: 'Elektrisch laden links',  icon: '⚡' },
  { id: 'pk_rechts',   name: 'Elektrisch laden rechts', icon: '⚡' },
  { id: 'pk_magazijn', name: 'Parkeerplaats magazijn',  icon: '🏭' },
];
const PK_SLOTS = [{ id: 'vm', label: 'Voormiddag' }, { id: 'nm', label: 'Namiddag' }];
const WEEKDAYS = ['Ma','Di','Wo','Do','Vr'];
const MONTHS_S = ['jan','feb','mrt','apr','mei','jun','jul','aug','sep','okt','nov','dec'];
const DAYS_NL = ['zondag','maandag','dinsdag','woensdag','donderdag','vrijdag','zaterdag'];

// ── STATE ────────────────────────────────────────────────────────
let sb = null;
let userName = '';
let dayOffset = 0;
let weekOffset = 0;
let wpReservations = {};
let pkReservations = {};
let activeTab = 'werkplekken';

// ── SUPABASE ─────────────────────────────────────────────────────
const SB_URL = 'https://fhltxltecvztwwozbkwn.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZobHR4bHRlY3Z6dHd3b3pia3duIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk5NTA3MjgsImV4cCI6MjA5NTUyNjcyOH0.HW0tRI6otgzAJ239qHRtKMi_EmPZRdV5F2iQXpSoS1I';

// ── DATE HELPERS ─────────────────────────────────────────────────
function getToday() { const d = new Date(); d.setHours(0,0,0,0); return d; }
function getSelectedDay() { const d = getToday(); d.setDate(d.getDate() + dayOffset); return d; }
function dateKey(d) { return d.toISOString().split('T')[0]; }
function isToday(d) { return d.toDateString() === getToday().toDateString(); }
function isPastHour(d, h) { const now = new Date(), cut = new Date(d); cut.setHours(h + 1, 0, 0, 0); return cut < now; }
function isPkPast(d, slot) { const now = new Date(), cut = new Date(d); cut.setHours(slot === 'vm' ? 12 : 23, 0, 0, 0); return cut < now; }
function getMonday(offset) { const now = new Date(), dow = now.getDay() || 7, mon = new Date(now); mon.setDate(now.getDate() - (dow - 1) + offset * 7); mon.setHours(0,0,0,0); return mon; }
function getWeekDates(offset) { const mon = getMonday(offset); return Array.from({length:5}, (_,i) => { const d = new Date(mon); d.setDate(mon.getDate()+i); return d; }); }
function getISOWeek(d) { const j = new Date(d.getFullYear(),0,4), s = new Date(j); s.setDate(j.getDate()-(j.getDay()||7)+1); return Math.round((d-s)/604800000)+1; }
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── LOAD DATA ────────────────────────────────────────────────────
async function loadWerkplekken() {
  if (!sb) return;
  const d = getSelectedDay();
  const dk = dateKey(d);
  setStatus('loading', 'Laden…');
  try {
    // Werkplekken gebruiken de 'reservations' tabel met type='werkplek'
    const { data, error } = await sb.from('reservations').select('*').eq('date', dk).eq('type', 'werkplek');
    if (error) throw error;
    wpReservations = {};
    (data||[]).forEach(r => { wpReservations[`${r.spot}||${r.slot}`] = { id: r.id, name: r.name }; });
    setStatus('');
  } catch(e) { setStatus('error', 'Kon werkplekken niet laden.'); }
  renderWerkplekken();
}

async function loadParking() {
  if (!sb) return;
  const dates = getWeekDates(weekOffset);
  setStatus('loading', 'Laden…');
  try {
    const { data, error } = await sb.from('reservations').select('*').eq('type', 'parking').gte('date', dateKey(dates[0])).lte('date', dateKey(dates[4]));
    if (error) throw error;
    pkReservations = {};
    (data||[]).forEach(r => { pkReservations[`${r.spot}||${r.date}||${r.slot}`] = { id: r.id, name: r.name }; });
    setStatus('');
  } catch(e) { setStatus('error', 'Kon parking niet laden.'); }
  renderParking();
}

// ── WERKPLEKKEN RENDER ───────────────────────────────────────────
function renderWerkplekken() {
  const d = getSelectedDay();
  const dk = dateKey(d);
  const dayName = DAYS_NL[d.getDay()];
  document.getElementById('wp-date-label').textContent = `${d.getDate()} ${MONTHS_S[d.getMonth()]} ${d.getFullYear()}`;
  document.getElementById('wp-day-label').textContent = isToday(d) ? '— vandaag' : `— ${dayName}`;

  const grid = document.getElementById('wp-grid');
  let html = '';
  html += '<div></div>';
  HOURS.forEach(h => { html += `<div class="wp-header">${h}u</div>`; });

  let lastGroup = null;
  WERKPLEKKEN.forEach(wp => {
    if (wp.group !== lastGroup) {
      if (lastGroup !== null) html += '<div class="section-gap"></div>';
      html += `<div class="section-label">${wp.group}</div>`;
      lastGroup = wp.group;
    }
    html += `<div class="wp-label"><div class="wname">${wp.name}</div>${wp.desc ? `<div class="wdesc">${wp.desc}</div>` : ''}</div>`;
    HOURS.forEach(h => {
      // slot = hour number stored as string, key uses spot||hour
      const key = `${wp.id}||${h}`;
      const res = wpReservations[key];
      const past = isPastHour(d, h);
      const isMe = res && res.name === userName && userName;
      let cls = 'wp-cell' + (past?' past':'') + (isMe?' mine':res?' taken':past?'':' free');
      const onclick = !past && (!res || isMe) ? `onclick="handleWpClick('${wp.id}',${h},'${dk}')"` : '';
      html += `<div class="${cls}" ${onclick} title="${wp.name} — ${h}:00-${h+1}:00">`;
      if (res) {
        html += isMe
          ? `<div class="cname">${escHtml(res.name)}</div>${!past?'<div class="cancel-hint">annuleren</div>':''}`
          : `<div class="tname">${escHtml(res.name)}</div>`;
      } else if (!past) {
        html += '<div class="plus">+</div>';
      }
      html += '</div>';
    });
  });
  grid.innerHTML = html;
}

// ── PARKING RENDER ───────────────────────────────────────────────
function renderParking() {
  const dates = getWeekDates(weekOffset);
  const mon = dates[0], fri = dates[4];
  document.getElementById('pk-week-label').textContent = `Week ${getISOWeek(mon)}`;
  document.getElementById('pk-week-range').textContent = `${mon.getDate()} ${MONTHS_S[mon.getMonth()]} – ${fri.getDate()} ${MONTHS_S[fri.getMonth()]} ${fri.getFullYear()}`;

  let html = '<div></div>';
  dates.forEach((d,i) => {
    const tod = isToday(d);
    html += `<div class="pk-col-header${tod?' today':''}"><div class="wd">${WEEKDAYS[i]}</div><div class="dd">${d.getDate()}</div><div class="mm">${MONTHS_S[d.getMonth()]} ${d.getFullYear()}</div>${tod?'<div class="today-dot"></div>':''}</div>`;
  });

  PARKING_SPOTS.forEach((spot, si) => {
    PK_SLOTS.forEach(slot => {
      html += `<div class="pk-row-label"><div class="pname">${spot.icon} ${spot.name}</div><div class="phalf">${slot.label}</div></div>`;
      dates.forEach(d => {
        const dk = dateKey(d), key = `${spot.id}||${dk}||${slot.id}`, res = pkReservations[key];
        const past = isPkPast(d, slot.id), tod = isToday(d);
        const isMe = res && res.name === userName && userName;
        let cls = 'pk-cell' + (past?' past':'') + (isMe?' mine':res?' taken':past?'':' free') + (tod&&!past?' today-col':'');
        const onclick = !past&&(!res||isMe) ? `onclick="handlePkClick('${spot.id}','${dk}','${slot.id}')"` : '';
        html += `<div class="${cls}" ${onclick}>`;
        if (res) {
          html += `<div style="font-size:12px">🚗</div>`;
          html += isMe ? `<div class="cname">${escHtml(res.name)}</div>${!past?'<div class="cancel-hint">annuleren</div>':''}` : `<div class="tname">${escHtml(res.name)}</div>`;
        } else if (!past) html += '<div class="plus">+</div>';
        html += '</div>';
      });
    });
    if (si < PARKING_SPOTS.length - 1) html += '<div class="pk-divider"></div>';
  });
  document.getElementById('pk-grid').innerHTML = html;
}

// ── CLICK HANDLERS ───────────────────────────────────────────────
async function handleWpClick(spotId, hour, dk) {
  if (!userName.trim()) { toast('Vul eerst je naam in.'); document.getElementById('username').focus(); return; }
  const key = `${spotId}||${hour}`, res = wpReservations[key];
  if (res && res.name === userName) {
    setStatus('loading','Annuleren…');
    try {
      const { error } = await sb.from('reservations').delete().eq('id', res.id);
      if (error) throw error;
      delete wpReservations[key]; setStatus(''); toast('Reservatie geannuleerd.');
    } catch(e) { setStatus('error','Annuleren mislukt.'); }
  } else if (!res) {
    setStatus('loading','Opslaan…');
    try {
      // slot field stores the hour as string, type='werkplek' to distinguish
      const { data, error } = await sb.from('reservations').insert([{ spot: spotId, date: dk, slot: String(hour), name: userName.trim(), type: 'werkplek' }]).select();
      if (error) throw error;
      wpReservations[key] = { id: data[0].id, name: data[0].name };
      setStatus(''); toast(`✓ ${WERKPLEKKEN.find(w=>w.id===spotId).name} — ${hour}:00-${hour+1}:00`);
    } catch(e) { setStatus('error','Opslaan mislukt.'); }
  }
  renderWerkplekken();
}

async function handlePkClick(spotId, dk, slotId) {
  if (!userName.trim()) { toast('Vul eerst je naam in.'); document.getElementById('username').focus(); return; }
  const key = `${spotId}||${dk}||${slotId}`, res = pkReservations[key];
  if (res && res.name === userName) {
    setStatus('loading','Annuleren…');
    try {
      const { error } = await sb.from('reservations').delete().eq('id', res.id);
      if (error) throw error;
      delete pkReservations[key]; setStatus(''); toast('Parkeerreservatie geannuleerd.');
    } catch(e) { setStatus('error','Annuleren mislukt.'); }
  } else if (!res) {
    setStatus('loading','Opslaan…');
    try {
      const { data, error } = await sb.from('reservations').insert([{ spot: spotId, date: dk, slot: slotId, name: userName.trim(), type: 'parking' }]).select();
      if (error) throw error;
      pkReservations[key] = { id: data[0].id, name: data[0].name };
      setStatus(''); toast(`✓ ${PARKING_SPOTS.find(s=>s.id===spotId).name} — ${PK_SLOTS.find(s=>s.id===slotId).label}`);
    } catch(e) { setStatus('error','Opslaan mislukt.'); }
  }
  renderParking();
}

// ── NAV ──────────────────────────────────────────────────────────
function changeDay(dir) {
  dayOffset += dir;
  const d = getSelectedDay();
  if (d.getDay() === 6) dayOffset += dir > 0 ? 2 : -1;
  if (d.getDay() === 0) dayOffset += dir > 0 ? 1 : -2;
  loadWerkplekken();
}
function changeWeek(dir) { weekOffset += dir; loadParking(); }

function switchTab(tab, event) {
  activeTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById(`tab-${tab}`).classList.add('active');
  if (tab === 'werkplekken') loadWerkplekken();
  else loadParking();
}

// ── UI HELPERS ───────────────────────────────────────────────────
function setStatus(type, msg) {
  const el = document.getElementById('status-bar');
  el.innerHTML = msg ? (type==='loading'?`<div class="spinner"></div>${msg}`:msg) : '';
  el.className = 'status-bar' + (type==='error'?' error':'');
}
function toast(msg) {
  const t = document.getElementById('toast'); t.textContent = msg;
  t.classList.add('show'); setTimeout(()=>t.classList.remove('show'), 2600);
}

// ── INIT ─────────────────────────────────────────────────────────
document.getElementById('username').addEventListener('input', e => {
  userName = e.target.value.trim();
  if (activeTab === 'werkplekken') renderWerkplekken();
  else renderParking();
});
document.getElementById('today-chip').textContent = new Date().toLocaleDateString('nl-BE',{weekday:'long',day:'numeric',month:'long'});

sb = window.supabase.createClient(SB_URL, SB_KEY);
loadWerkplekken();
</script>
